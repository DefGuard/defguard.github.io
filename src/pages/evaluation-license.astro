---
import Navigation from "../components/base/Navigation.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentLimiter from "../components/ContentLimiter.astro";
import BookEvaluationLicenseForm from "../components/form/BookDemoForm/BookEvaluationLicenseForm";
import OrganizationJSONLD from "../scripts/OrganizationJSONLD.astro";
import TrustedBy from "./_home/components/TrustedBy.astro";

const title = "Request Evaluation License - defguard Enterprise VPN";
const featuredImage =
  "github.com/DefGuard/defguard.github.io/raw/main/public/images/png/defguard.png";
const imageWidth = "1080";
const imageHeight = "540";
const description = "Request a 14-day free evaluation license for defguard enterprise VPN with full WireGuard® MFA/2FA and SSO integration capabilities.";
const url = "https://defguard.net/evaluation-license/";
const tags = [
  "defguard",
  "evaluation",
  "trial",
  "free trial",
  "WireGuard®",
  "enterprise vpn",
  "mfa/2fa",
  "sso",
  "proof of concept",
  "license",
];
---

<BaseLayout
  title={title}
  description={description}
  featuredImage={featuredImage}
  imageWidth={imageWidth}
  imageHeight={imageHeight}
  url={url}
>
  <OrganizationJSONLD
    slot="schema"
    title={title}
    description={description}
    url={url}
    tags={tags}
  />
  <Navigation activeSlug="/evaluation-license/" />

  <main id="evaluation-license-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <ContentLimiter maxWidth={1200}>
        <div class="hero-grid">
          <div class="hero-content">
            <span class="hero-badge">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="6" width="10" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
                <path d="M4 6V4C4 2.34315 5.34315 1 7 1C8.65685 1 10 2.34315 10 4V6" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              14-Day Evaluation
            </span>
            <h1>Try Defguard Free for 14 Days</h1>
            <p class="hero-subtitle">
              Evaluate Defguard for your infrastructure, compliance requirements, and deployment scale. We provide a 14-day free evaluation license with full enterprise features and technical support.
            </p>

            <div class="hero-benefits">
              <div class="benefit-item">
                <svg class="benefit-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="9" cy="9" r="8" stroke="#0C8CE0" stroke-width="2"/>
                  <path d="M5 9L8 12L13 6" stroke="#0C8CE0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Full access to all enterprise features for 14 days</span>
              </div>
              <div class="benefit-item">
                <svg class="benefit-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="9" cy="9" r="8" stroke="#0C8CE0" stroke-width="2"/>
                  <path d="M5 9L8 12L13 6" stroke="#0C8CE0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Technical support with Defguard during your trial</span>
              </div>
              <div class="benefit-item">
                <svg class="benefit-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="9" cy="9" r="8" stroke="#0C8CE0" stroke-width="2"/>
                  <path d="M5 9L8 12L13 6" stroke="#0C8CE0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>License delivered via email after we review your request</span>
              </div>
            </div>

            <p class="hero-note">
              Please provide your company information (name, address and Tax Identification Number) in the form for convenience.
            </p>
          </div>

          <div class="hero-form">
            <div class="form-card">
              <h2>Request Evaluation License</h2>
              <p class="form-subtitle">We typically respond within 24 hours</p>
              <BookEvaluationLicenseForm submit_text="Request Evaluation License" client:load />
              <p class="form-privacy">
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="6" width="10" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M4 6V4C4 2.34315 5.34315 1 7 1C8.65685 1 10 2.34315 10 4V6" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                Your data stays private. We never share your information.
              </p>
            </div>
          </div>
        </div>
      </ContentLimiter>
    </section>

    <!-- Trusted By -->
    <section class="trusted-section">
      <TrustedBy />
    </section>
  </main>
</BaseLayout>

<style lang="scss" is:global>
  #evaluation-license-page {
    /* Hero Section - matches book-a-demo */
    .hero-section {
      background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
      padding: 80px 20px;

      @media (max-width: 768px) {
        padding: 40px 20px;
      }
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;

      @media (max-width: 968px) {
        grid-template-columns: 1fr;
        gap: 40px;
      }
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--surface-main-primary);
      color: white;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 20px;

      svg {
        flex-shrink: 0;
      }
    }

    .hero-content h1 {
      font-size: 2.5rem;
      line-height: 1.2;
      color: var(--text-body-primary);
      margin-bottom: 20px;

      @media (max-width: 768px) {
        font-size: 1.875rem;
      }
    }

    .hero-subtitle {
      font-size: 1.125rem;
      line-height: 1.7;
      color: var(--text-body-secondary);
      margin-bottom: 30px;
    }

    .hero-benefits {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .benefit-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 15px;
      color: var(--text-body-primary);

      .benefit-icon {
        flex-shrink: 0;
      }
    }

    .hero-note {
      font-size: 14px;
      color: var(--text-body-secondary);
      margin-top: 24px;
      line-height: 1.6;
    }

    .hero-form {
      @media (max-width: 968px) {
        order: -1;
      }
    }

    .form-card {
      background: white;
      border-radius: 16px;
      padding: 40px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);

      h2 {
        font-size: 1.5rem;
        margin-bottom: 8px;
        color: var(--text-body-primary);
      }

      .form-subtitle {
        font-size: 14px;
        color: var(--text-body-secondary);
        margin-bottom: 24px;
      }

      .form-privacy {
        font-size: 13px;
        color: var(--text-body-secondary);
        text-align: center;
        margin-top: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;

        svg {
          flex-shrink: 0;
        }
      }
    }

    /* Trusted Section - matches book-a-demo */
    .trusted-section {
      background: white;
      padding: 20px 0;
      border-bottom: 1px solid var(--border-separator, #e5e7eb);
    }
  }
</style>
