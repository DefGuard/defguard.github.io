---
interface Props {
  successMessage?: string;
  errorMessage?: string;
  debug?: boolean;
}

const {
  successMessage = "Thanks for subscribing!",
  errorMessage = "Something went wrong. Please try again.",
  debug = false
} = Astro.props;
---

<script>
  interface FormState {
    isSubmitting: boolean;
    isSuccess: boolean;
    isError: boolean;
    message: string;
  }

  // Track initialization status
  let isInitialized = false;

  class NewsletterForm extends HTMLElement {
    form: HTMLFormElement;
    emailInput: HTMLInputElement;
    submitButton: HTMLButtonElement;
    messageElement: HTMLDivElement;
    state: FormState;

    constructor() {
      super();
      this.form = this.querySelector('form') as HTMLFormElement;
      this.emailInput = this.querySelector('input[type="email"]') as HTMLInputElement;
      this.submitButton = this.querySelector('button[type="submit"]') as HTMLButtonElement;
      this.messageElement = this.querySelector('.form-message') as HTMLDivElement;
      
      this.state = {
        isSubmitting: false,
        isSuccess: false,
        isError: false,
        message: '',
      };

      this.initialize();
    }

    initialize() {
      this.form.addEventListener('submit', async (e) => {
        e.preventDefault();
        await this.handleSubmit();
      });

      this.emailInput.addEventListener('input', () => {
        this.resetState();
      });
    }

    async handleSubmit() {
      if (this.state.isSubmitting) return;
      
      const email = this.emailInput.value;
      if (!email || !this.emailInput.checkValidity()) {
        this.updateState({
          isError: true,
          message: 'Please enter a valid email address',
        });
        return;
      }

      this.updateState({ isSubmitting: true });
      this.submitButton.disabled = true;

      try {
        // Replace this with your actual API endpoint
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (!response.ok) throw new Error('Subscription failed');

        this.updateState({
          isSuccess: true,
          message: this.getAttribute('success-message') || 'Thanks for subscribing!',
        });
        this.form.reset();
      } catch (error) {
        this.updateState({
          isError: true,
          message: this.getAttribute('error-message') || 'Something went wrong. Please try again.',
        });
      } finally {
        this.updateState({ isSubmitting: false });
        this.submitButton.disabled = false;
      }
    }

    updateState(newState: Partial<FormState>) {
      this.state = { ...this.state, ...newState };
      this.updateUI();
    }

    resetState() {
      this.updateState({
        isSuccess: false,
        isError: false,
        message: '',
      });
    }

    updateUI() {
      this.messageElement.textContent = this.state.message;
      this.messageElement.className = 'form-message ' + 
        (this.state.isSuccess ? 'success' : this.state.isError ? 'error' : '');
      
      this.submitButton.textContent = this.state.isSubmitting ? 'Subscribing...' : 'Subscribe';
    }
  }

  // Initialize visibility handling
  function initSlideIn() {
    const slideIn = document.querySelector('.slide-in-container');
    if (!slideIn || slideIn.classList.contains('debug-visible')) return;

    // Initial state
    slideIn.classList.add('initial-hidden');
    let isFirstScroll = true;

    const minScrollThreshold = 100; // Minimum scroll before showing
    const showSlideInAt = window.innerHeight * 0.3; // Show at 30% of viewport height

    function checkSlide() {
      const scrolled = window.scrollY;

      // Remove initial hidden state only after minimum scroll
      if (isFirstScroll && scrolled > minScrollThreshold) {
        isFirstScroll = false;
        setTimeout(() => {
          slideIn.classList.remove('initial-hidden');
        }, 500); // Longer delay for smoother appearance
      }
      
      // Show/hide based on scroll position
      if (!isFirstScroll && scrolled > showSlideInAt) {
        slideIn.classList.add('active');
      } else {
        slideIn.classList.remove('active');
      }
    }

    // Initial check
    checkSlide();

    // Throttle scroll event for better performance
    let timeout: number;
    window.addEventListener('scroll', () => {
      if (timeout) {
        window.cancelAnimationFrame(timeout);
      }
      timeout = window.requestAnimationFrame(checkSlide);
    });
  }

  // Single initialization point
  function init() {
    if (isInitialized) return;
    isInitialized = true;

    // Define custom element only once
    if (!customElements.get('newsletter-form')) {
      customElements.define('newsletter-form', NewsletterForm);
    }

    // Initialize slide-in visibility
    initSlideIn();
  }

  // Initialize immediately if DOM is ready, otherwise wait for DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<div
  class:list={["slide-in-container", { "debug-visible": debug }]}
  data-testid="newsletter-slide-in"
  client:visible
>
  <div class="slide-in-content">
    <newsletter-form 
      success-message={successMessage} 
      error-message={errorMessage}
      class="newsletter-form-component"
    >
      <h3>Subscribe to our newsletter</h3>
      <form id="newsletter-form" class="newsletter-form">
        <input 
          type="email" 
          name="email" 
          placeholder="Enter your email" 
          required
          pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
          aria-label="Email address"
        />
        <button type="submit">Subscribe</button>
        <div class="form-message" role="status" aria-live="polite"></div>
      </form>
    </newsletter-form>
  </div>
</div>

<style>
  .slide-in-container {
    position: fixed;
    bottom: 0;
    right: 2rem;
    background: white;
    padding: 1.5rem;
    border-radius: 0px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease-in-out;
    z-index: 99999;
    max-width: 400px;
    width: calc(100% - 4rem);
    transform: translateY(100%);
    opacity: 0;
  }

  .slide-in-container.initial-hidden {
    opacity: 0 !important;
    transform: translateY(100%) !important;
    pointer-events: none;
  }

  /* Debug mode styling */
  .slide-in-container.debug-visible {
    bottom: 0 !important;
    transform: translateY(-2rem) !important;
    opacity: 1 !important;
    visibility: visible !important;
    border-top: 2px solid white;
    border-color: var(--primary-color, #0C8CE0);
  }

  .slide-in-container.active {
    transform: translateY(-2rem);
    opacity: 1;
  }

  .slide-in-content {
    text-align: center;
  }

  h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2rem;
    color: #333;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  input[type="email"] {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem 1rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
  }

  button {
    padding: 0.5rem 1.5rem;
    background: var(--primary-color, #0C8CE0);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background 0.2s ease;
  }

  button:hover {
    background: #0052a3;
  }

  .form-message {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    min-height: 1.25rem;
    transition: all 0.2s ease;
  }

  .form-message.success {
    color: #22c55e;
  }

  .form-message.error {
    color: #ef4444;
  }

  button:disabled {
    background: #93c5fd;
    cursor: not-allowed;
  }

  @media (max-width: 480px) {
    .slide-in-container {
      right: 1rem;
      width: calc(100% - 2rem);
    }

    .newsletter-form {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }
</style>

